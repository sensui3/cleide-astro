---
const services = [
  {
    title: 'Psicanálise',
    description: 'Exploração do inconsciente através da fala livre, revelando desejos e conflitos reprimidos que moldam nosso comportamento atual. Foco na compreensão profunda do eu.',
    icon: 'i-lucide-brain-circuit'
  },
  {
    title: 'Terapia de Regressão',
    description: 'Acessando memórias profundas para liberar bloqueios emocionais e traumas que permanecem latentes no psiquismo, permitindo uma cura desde a raiz.',
    icon: 'i-lucide-history'
  },
  {
    title: 'Psicologia Transpessoal',
    description: 'A quarta força da psicologia, que integra os aspectos espirituais e transcendentais da experiência humana ao processo de desenvolvimento pessoal.',
    icon: 'i-lucide-sparkles'
  },
  {
    title: 'Hipnose Clínica',
    description: 'Uso terapêutico da hipnose para facilitar mudanças comportamentais rápidas e eficazes em estados profundos de relaxamento e foco.',
    icon: 'i-lucide-eye'
  }
];
---

<section id="tratamentos" class="section-padding bg-slate-50/30 reveal">
  <div class="container">
    <div class="grid lg:grid-cols-12 gap-16 items-start">
      <div class="lg:col-span-4 sticky top-40">
        <span class="inline-block text-xs font-bold tracking-[0.2em] text-slate-400 uppercase mb-8">
          // ESPECIALIDADES
        </span>
        <h2 class="font-display text-[clamp(2.5rem,4vw,4rem)] text-brand-700 leading-tight mb-8">
          Tratamentos & Abordagens
        </h2>
        <p class="text-slate-400 text-lg mb-10 leading-relaxed">
          Utilizamos uma combinação cuidadosa de técnicas para oferecer um suporte completo ao ser humano em sua integralidade. Cada abordagem é selecionada conforme a necessidade do paciente.
        </p>
        <a href="/tratamentos/" class="text-xs font-bold tracking-[0.2em] text-brand-500 hover:text-brand-600 transition-colors uppercase border-b-2 border-brand-500/20 pb-1">
          Ver todos os tratamentos
        </a>
      </div>

      <div class="lg:col-span-8 grid sm:grid-cols-2 gap-8">
        {services.map(service => (
          <div class="p-12 bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 group ring-1 ring-slate-50">
            <div class="w-14 h-14 bg-brand-50 text-brand-500 rounded-full flex items-center justify-center mb-10 group-hover:bg-brand-500 group-hover:text-white transition-all">
              <span class={service.icon + " text-2xl"}></span>
            </div>
            <h3 class="font-display font-medium text-2xl mb-6 text-brand-700">{service.title}</h3>
            <p class="text-slate-400 text-base leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
