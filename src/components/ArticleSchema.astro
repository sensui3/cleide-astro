---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  image?: string;
  authorName?: string;
}

const { 
  title, 
  description, 
  publishedAt, 
  image, 
  authorName = "Dra. Cleide Salem Sarkis" 
} = Astro.props;

const siteUrl = Astro.site || 'https://cleidesarkis.com.br';
const imageUrl = image ? new URL(image, siteUrl).href : '';

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": publishedAt.toISOString(),
  "author": {
    "@type": "Person",
    "name": authorName
  },
  ...(imageUrl && { "image": imageUrl })
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
