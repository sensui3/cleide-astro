---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  image?: string | any;
  authorName?: string;
}

const { 
  title, 
  description, 
  publishedAt, 
  image, 
  authorName = "Dra. Cleide Salem Sarkis" 
} = Astro.props;

const siteUrl = Astro.site || 'https://cleidesarkis.com.br';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const imageUrl = image 
  ? (typeof image === 'string' ? new URL(image, siteUrl).href : new URL(image.src, siteUrl).href)
  : '';

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": currentUrl,
  "datePublished": publishedAt.toISOString(),
  "author": {
    "@type": "Person",
    "name": authorName
  },
  ...(imageUrl && { "image": imageUrl })
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
