---
import { Image } from 'astro:assets';
import { getWhatsappUrl } from '../utils/whatsapp';
import drImage from '../assets/cleide-sarkis.webp';

const { pathname } = Astro.url;
const whatsappUrl = getWhatsappUrl(pathname);
---

<section class="relative min-h-[70vh] flex items-center pt-24 pb-20 overflow-hidden bg-white reveal">
  <div class="container relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 max-w-2xl">

        
        <h1 class="heading-1 mb-10">
          Você não precisa carregar <span class="italic font-300 text-brand-500">esse peso</span> sozinha
        </h1>
        
        <p class="text-main text-slate-400 mb-12 max-w-xl">
          Há mais de 15 anos, ajudo pessoas a compreenderem o que está por trás da ansiedade, do esgotamento e da dor emocional — para que possam viver com mais leveza e clareza.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 items-center sm:items-start">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white pl-4 pr-10 py-3 rounded-full font-bold flex items-center gap-4 hover:bg-[#128C7E] transition-all shadow-xl shadow-green-500/10 w-fit group uppercase tracking-widest text-base">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center group-hover:bg-white/30 transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.418 0 .014 5.42-.014 12.053c0 2.12.553 4.189 1.605 6.02L0 24l6.117-1.605a11.81 11.81 0 005.9 1.547h.005c6.632 0 12.036-5.42 12.039-12.054a11.85 11.85 0 00-3.417-8.436z"/>
              </svg>
            </div>
            Quero dar o primeiro passo
          </a>
          
          <a href="/primeira-sessao/" class="border-2 border-slate-200 text-slate-600 px-8 py-3 rounded-full font-bold flex items-center gap-3 hover:border-brand-500 hover:text-brand-500 transition-all text-base uppercase tracking-widest">
            Como funciona?
          </a>
        </div>
        
        <p class="text-[10px] text-slate-400 mt-4 ml-1 uppercase tracking-widest font-bold opacity-60">
          // Conversa inicial pelo WhatsApp, sem compromisso.
        </p>
      </div>
      
      <div class="lg:col-span-6 relative">
        <div class="relative w-full aspect-square rounded-[3rem] overflow-hidden bg-slate-100 border-b-[20px] border-brand-500 shadow-2xl">
           <Image src={drImage} alt="Dra. Cleide Sarkis" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
        </div>
        
        <!-- Badge -->
        <div class="absolute bottom-10 -left-10 bg-white p-8 rounded-2xl shadow-2xl max-w-[280px] border border-slate-50 flex items-start gap-5">
          <div class="w-4 h-4 rounded-full bg-brand-500 mt-2 shrink-0"></div>
          <div>
            <p class="text-xs font-black tracking-widest uppercase text-brand-700 mb-2">ESPECIALISTA</p>
            <p class="text-sm text-slate-500 leading-relaxed font-medium">Psicanálise Clínica e Abordagem Transpessoal</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
