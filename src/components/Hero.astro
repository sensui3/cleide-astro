---
import { Image } from 'astro:assets';
import { getWhatsappUrl } from '../utils/whatsapp';
import drImage from '../../public/images/cleide-sarkis.webp';

const { pathname } = Astro.url;
const whatsappUrl = getWhatsappUrl(pathname);
---

<section class="relative min-h-[85vh] flex items-center pt-32 pb-20 overflow-hidden bg-white reveal">
  <div class="container relative z-10">
    <div class="grid lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-7 max-w-2xl">
        <span class="inline-block text-xs font-bold tracking-[0.2em] text-slate-400 uppercase mb-8">
          // ESPAÇO DE ACOLHIMENTO
        </span>
        
        <h1 class="font-display text-[clamp(4rem,10vw,7rem)] leading-[0.95] text-brand-700 mb-10">
          Cuidando<br class="hidden lg:block" /> da sua <br class="hidden lg:block" /><span class="italic font-300 text-brand-500">saúde mental</span>
        </h1>
        
        <p class="text-body text-2xl text-slate-400 mb-12 max-w-xl leading-relaxed">
          Um caminho de autoconhecimento e cura através de uma abordagem integrativa e humanizada da psicologia, onde cada história é ouvida com respeito.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white pl-4 pr-10 py-3 rounded-full font-bold flex items-center gap-4 hover:bg-[#128C7E] transition-all shadow-xl shadow-green-500/10 w-fit group uppercase tracking-widest text-base">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center group-hover:bg-white/30 transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.412c-2.135 0-4.215-.571-6.035-1.654L2 21l.887-3.491c-1.187-1.921-1.815-4.137-1.815-6.417 0-6.621 5.389-12 12-12s12 5.379 12 12-5.389 12-12 12m0-22c-5.514 0-10 4.486-10 10 0 2.123.663 4.113 1.811 5.764l-1.192 4.696 4.844-1.268C10.155 20.334 12.002 18 14 18c5.514 0 10-4.486 10-10S19.514 2 14 2z"/></svg>
            </div>
            Agendar Consulta
          </a>
        </div>
      </div>
      
      <div class="lg:col-span-5 relative">
        <div class="relative w-full aspect-[4/5] rounded-full overflow-hidden bg-slate-100 border-b-[20px] border-brand-500 shadow-2xl">
           <Image src={drImage} alt="Dra. Cleide Sarkis" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
        </div>
        
        <!-- Badge -->
        <div class="absolute bottom-10 -left-10 bg-white p-8 rounded-2xl shadow-2xl max-w-[280px] border border-slate-50 flex items-start gap-5">
          <div class="w-4 h-4 rounded-full bg-brand-500 mt-2 shrink-0"></div>
          <div>
            <p class="text-xs font-black tracking-widest uppercase text-brand-700 mb-2">ESPECIALISTA</p>
            <p class="text-sm text-slate-500 leading-relaxed font-medium">Psicanálise Clínica e Abordagem Transpessoal</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
