---
const steps = [
  {
    title: 'Acolhimento & Ética',
    description: 'O início de uma aliança terapêutica sólida, em um ambiente de absoluto sigilo e suspensão de julgamentos.',
  },
  {
    title: 'Investigação Analítica',
    description: 'Mergulho técnico nas causas raízes dos conflitos, decodificando o que está latente no seu psiquismo.',
  },
  {
    title: 'Expansão da Consciência',
    description: 'A conquista de clareza estratégica sobre seus padrões, gerando insights que permitem novas escolhas de vida.',
  },
  {
    title: 'Maestria & Ressignificação',
    description: 'A transformação definitiva de traumas em força consciente, permitindo o domínio pleno da sua história.',
  }
];
---

<section id="processo" class="section-padding bg-white relative reveal">
  <div class="container">
    <div class="text-center mb-20">
      <span class="text-label mb-4 block">
        // O PROCESSO TERAPÊUTICO
      </span>
      <h2 class="heading-2">
        Jornada de <span class="italic font-300 text-brand-500">Transformação</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative p-12 bg-white border border-slate-50 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 group overflow-hidden">
          <span class="absolute -top-4 -right-2 text-[12rem] font-display font-black text-slate-50 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity leading-none select-none">
            {index + 1}
          </span>
          
          <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center text-brand-500 font-display font-bold text-base mb-10 group-hover:bg-brand-500 group-hover:text-white transition-colors relative z-10">
            {index + 1}
          </div>
          
          <h3 class="text-lg font-display font-bold text-brand-700 mb-6 relative z-10 leading-tight">{step.title}</h3>
          <p class="text-slate-500 text-sm relative z-10 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
