---
import BaseLayout from './BaseLayout.astro';
import Contact from '../components/Contact.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroText: string;
}

const { title, description, heroTitle, heroText } = Astro.props;
---

<BaseLayout {title} {description}>
  <section class="pt-40 pb-20 bg-brand-50 border-b border-brand-100">
    <div class="container text-center">
      <h1 class="heading-1 mb-6">{heroTitle}</h1>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">{heroText}</p>
    </div>
  </section>

  <section class="section-padding container">
    <div class="grid lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2 prose prose-slate prose-lg max-w-2xl">
        <slot />
      </div>
      
      <aside class="space-y-8">
        <div class="p-8 bg-brand-600 rounded-3xl text-white shadow-xl">
          <h3 class="font-display font-bold text-2xl mb-4">Inicie sua terapia</h3>
          <p class="mb-8 text-brand-100">Dê o primeiro passo para uma vida mais equilibrada.</p>
          <a href="https://wa.me/5511998059125" class="w-full bg-white text-brand-600 py-4 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-brand-50 transition-colors">
            Falar no WhatsApp
            <span class="i-lucide-message-circle"></span>
          </a>
        </div>

        <div class="p-8 border border-slate-200 rounded-3xl">
          <h3 class="font-display font-bold text-xl mb-6 text-slate-900">Outros Tratamentos</h3>
          <ul class="space-y-4">
            <li><a href="/psicanalise/" class="text-slate-600 hover:text-brand-500 flex items-center gap-2"><span class="i-lucide-chevron-right text-xs"></span> Psicanálise</a></li>
            <li><a href="/terapia-ansiedade/" class="text-slate-600 hover:text-brand-500 flex items-center gap-2"><span class="i-lucide-chevron-right text-xs"></span> Ansiedade</a></li>
            <li><a href="/terapia-depressao/" class="text-slate-600 hover:text-brand-500 flex items-center gap-2"><span class="i-lucide-chevron-right text-xs"></span> Depressão</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <Contact />
</BaseLayout>
