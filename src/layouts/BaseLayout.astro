---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';

import logo from '../assets/cleide-sarkis-logo.svg';

interface Props {
  title: string;
  description: string;
  image?: string;
  structuredData?: object;
  showHeader?: boolean;
  showFooter?: boolean;
}

const { 
  title, 
  description, 
  image, 
  structuredData,
  showHeader = true,
  showFooter = true 
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/x-icon" href="/images/cleide-icon.ico" />
    <link rel="shortcut icon" href="/images/cleide-icon.ico" />
    <link rel="apple-touch-icon" href="/images/cleide-icon.ico" />
    <SEO {title} {description} {image} {structuredData} />
    
    <!-- Preload fonts to avoid layout shift -->
    <link rel="preload" href={logo.src} as="image" type="image/svg+xml" />
    <link rel="preload" href="/fonts/fraunces-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-300-italic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-400.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-white text-slate-900 font-body antialiased selection:bg-brand-100 selection:text-brand-900">
    {showHeader && (
      <slot name="header">
        <Header />
      </slot>
    )}
    
    <main id="main-content">
      <slot />
    </main>
    
    {showFooter && (
      <slot name="footer">
        <Footer />
      </slot>
    )}
    
    <FloatingCTA />
    
    <style is:global>
      :root {
        scroll-behavior: smooth;
      }

      /* Scroll Animation for Header Shadow (Modern CSS) */
      @keyframes header-shadow {
        from { box-shadow: none; border-bottom-color: transparent; }
        to { box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1); border-bottom-color: var(--color-slate-50); }
      }

      #main-header {
        animation: header-shadow 0.1s linear both;
        animation-timeline: scroll();
        animation-range: 0 50px;
      }

      /* Back to Top Visibility */
      @keyframes back-to-top-anim {
        from { opacity: 0; transform: translateY(20px); pointer-events: none; }
        to { opacity: 1; transform: translateY(0); pointer-events: auto; }
      }

      #back-to-top {
        animation: back-to-top-anim 0.1s linear both;
        animation-timeline: scroll();
        animation-range: 0 500px;
      }

      /* Reveal Animations */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }

      [data-aos] {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }

      [data-aos].aos-animate {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Accessibility: focus indicator */
      :focus-visible {
        outline: 3px solid var(--color-brand-500);
        outline-offset: 2px;
      }
      
      .skip-link {
        @apply sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-white focus:p-4 focus:shadow-xl focus:rounded-lg;
      }
    </style>

    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
