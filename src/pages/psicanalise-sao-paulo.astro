---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
import FAQ from '../components/FAQ.astro';
import { getWhatsappUrl } from '../utils/whatsapp';

const { pathname } = Astro.url;
const whatsappUrl = getWhatsappUrl(pathname);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Psychologist",
      "name": "Dra. Cleide Sarkis - Psicanalista em São Paulo",
      "image": "https://cleidesarkis.com.br/logo.png",
      "description": "Atendimento psicanalítico especializado na região da Avenida Paulista e Vila Mariana. Especialista em traumas, ansiedade e depressão.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Paulista, 509 - Conj. 1513",
        "addressLocality": "São Paulo",
        "addressRegion": "SP",
        "postalCode": "01311-000",
        "addressCountry": "BR"
      },
      "url": "https://cleidesarkis.com.br/psicanalise-sao-paulo/",
      "telephone": "+5511998059125"
    }
  ]
};

const localizedFaqs = [
  {
    question: "Onde realizar psicanálise em São Paulo?",
    answer: "A Dra. Cleide Sarkis atende presencialmente na Avenida Paulista, 509 (próximo ao Metrô Brigadeiro), abrangendo pacientes de toda a capital paulista."
  },
  {
    question: "Como funciona o atendimento presencial em SP?",
    answer: "As sessões ocorrem em consultório privativo, com total sigilo e conforto. O agendamento é feito previamente via WhatsApp para garantir a melhor organização na agenda."
  },
  {
    question: "Atende convênios em São Paulo?",
    answer: "Sim, atendemos Cabesp, Vivest, OAB e SulAmérica. Para outras operadoras, fornecemos o recibo para reembolso."
  }
];
---

<BaseLayout 
  title="Psicanalista em São Paulo" 
  description="Dra. Cleide Sarkis oferece sessões de psicanálise presenciais na Avenida Paulista e online. Especialista em traumas, ansiedade e depressão."
  {structuredData}
>
  
  <section class="pt-40 pb-20 bg-brand-50">
    <div class="container text-center">
      <h1 class="heading-1 mb-8">Psicanalista em São Paulo</h1>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        Atendimento especializado para quem busca autoconhecimento e alívio do sofrimento emocional no coração de SP.
      </p>
    </div>
  </section>

  <article class="section-padding container">
    <div class="grid lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2 prose prose-slate prose-lg max-w-none">
        <h2>Por que buscar Psicanálise em São Paulo?</h2>
        <p>
          Viver em uma metrópole como São Paulo exige muito da nossa saúde mental. O ritmo acelerado, o estresse do cotidiano e a pressão constante podem gerar quadros de ansiedade e esgotamento. 
          A <strong>psicanálise</strong> oferece uma pausa necessária, um refúgio para investigar as causas profundas desse mal-estar.
        </p>

        <h3>Benefícios do Tratamento Psicanalítico</h3>
        <p>
          Diferente de abordagens focadas apenas em sintomas imediatos, a psicanálise mergulha no inconsciente para entender como traumas passados e padrões repetitivos influenciam sua vida hoje.
        </p>
        <ul>
          <li>Compreensão da ansiedade e suas raízes;</li>
          <li>Superação de traumas de infância ou eventos recentes;</li>
          <li>Melhora nos relacionamentos interpessoais;</li>
          <li>Aumento da autoestima e segurança emocional.</li>
        </ul>

        <h3>Atendimento na Avenida Paulista e Arredores</h3>
        <p>
          Meu consultório está estrategicamente localizado na <strong>Avenida Paulista, 509</strong>, no bairro da <strong>Bela Vista</strong>. A localização é privilegiada para quem busca atendimento próximo ao <strong>Metrô Brigadeiro</strong>, facilitando o acesso para quem trabalha ou reside em bairros vizinhos como:
        </p>
        <ul>
          <li><strong>Paraíso:</strong> A poucos minutos de distância, ideal para quem vem da Zona Sul.</li>
          <li><strong>Vila Mariana:</strong> Região tradicional com forte conexão com o consultório.</li>
          <li><strong>Jardins / Jardim Paulista:</strong> Proximidade imediata para moradores e profissionais da região.</li>
          <li><strong>Consolação e Centro:</strong> Acesso rápido via metrô e ônibus.</li>
        </ul>
        <p>
          Além do atendimento presencial, também oferecemos a opção de <strong>terapia online</strong>, mantendo a mesma qualidade e profundidade do atendimento para quem prefere a comodidade de sua residência.
        </p>
      </div>
      
      <aside class="space-y-8">
        <div class="p-8 bg-brand-500 rounded-3xl text-white shadow-xl">
          <h3 class="font-display font-bold text-2xl mb-4">Agende sua sessão</h3>
          <p class="mb-8 text-brand-100 italic">Disponibilidade para atendimento presencial e online.</p>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="w-full bg-white text-brand-500 py-4 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-brand-50 transition-colors">
            Falar no WhatsApp
            <span class="i-lucide-arrow-right"></span>
          </a>
        </div>
        
        <div class="p-8 border border-slate-200 rounded-3xl">
          <h3 class="font-display font-bold text-xl mb-6 text-slate-900">Áreas de Foco</h3>
          <ul class="space-y-4">
            <li class="flex items-center gap-3 text-slate-600">
               <span class="w-2 h-2 rounded-full bg-brand-500"></span>
               Ansiedade Generalizada
            </li>
            <li class="flex items-center gap-3 text-slate-600">
               <span class="w-2 h-2 rounded-full bg-brand-500"></span>
               Depressão e Desânimo
            </li>
            <li class="flex items-center gap-3 text-slate-600">
               <span class="w-2 h-2 rounded-full bg-brand-500"></span>
               Conflitos Amorosos
            </li>
            <li class="flex items-center gap-3 text-slate-600">
               <span class="w-2 h-2 rounded-full bg-brand-500"></span>
               Síndrome de Burnout
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </article>

  <FAQ faqs={localizedFaqs} />
  <Contact />
</BaseLayout>
