---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import ArticleSchema from '../../components/ArticleSchema.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description}
  type="article"
>
  <ArticleSchema 
    title={post.data.title}
    description={post.data.description}
    publishedAt={post.data.publishedAt}
    image={post.data.image}
    slot="header"
  />
  <Header slot="header" />
  
  <article class="pt-40 pb-20 container max-w-4xl">
    <header class="mb-12 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-500 bg-brand-50 px-3 py-1 rounded-full">
          {post.data.category}
        </span>
        <span class="text-slate-400 text-sm">{post.data.publishedAt.toLocaleDateString('pt-BR')}</span>
      </div>
      <h1 class="heading-1 mb-8">{post.data.title}</h1>

      {post.data.image && (
        <div class="rounded-2xl overflow-hidden shadow-2xl mb-12 aspect-video bg-slate-100">
          <Image 
            src={post.data.image} 
            alt={post.data.alt || post.data.title}
            width={1200}
            height={675}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </div>
      )}
    </header>

    <div class="prose prose-slate prose-lg max-w-none prose-headings:font-display prose-headings:text-brand-700 prose-a:text-brand-500 hover:prose-a:text-brand-600 transition-colors">
      <Content />
    </div>
    
    <div class="mt-20 pt-10 border-t border-slate-100 flex justify-between items-center">
      <a href="/blog/" class="btn-ghost !px-6 !py-2 text-sm">
        <span class="i-lucide-arrow-left"></span>
        Voltar para o blog
      </a>
      <div class="flex gap-4">
        <span class="text-sm font-bold text-slate-400">Compartilhar:</span>
        <div class="flex gap-2">
           <button class="w-8 h-8 rounded-full bg-brand-50 text-brand-500 flex items-center justify-center hover:bg-brand-500 hover:text-white transition-all"><span class="i-lucide-share-2 text-sm"></span></button>
        </div>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
