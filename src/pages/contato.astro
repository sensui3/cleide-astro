---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getWhatsappUrl } from '../utils/whatsapp';

const { pathname } = Astro.url;
const whatsappUrl = getWhatsappUrl(pathname);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contato - Dra. Cleide Salem Sarkis",
  "description": "Entre em contato com a Dra. Cleide Sarkis para agendar sua consulta de psicanálise em São Paulo ou online.",
  "url": "https://cleidesarkis.com.br/contato/"
};
---

<BaseLayout 
  title="Contato | Dra. Cleide Salem Sarkis - Psicanalista em São Paulo" 
  description="Entre em contato para agendar sua consulta de psicanálise. Atendimento presencial na Av. Paulista e online para todo o Brasil."
  {structuredData}
>
  <Header slot="header" />
  
  <main class="pt-40 pb-20">
    <section class="container max-w-6xl">
      <div class="text-center mb-16">
        <span class="inline-block text-xs font-bold tracking-[0.2em] text-slate-400 uppercase mb-4">
          // CANAIS DE ATENDIMENTO
        </span>
        <h1 class="heading-1 mb-8">Vamos Conversar?</h1>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Escolha o canal de sua preferência para tirar dúvidas ou agendar sua primeira sessão. Estou à disposição para ouvir sua história.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Contact Info Cards -->
        <div class="space-y-6">
          <div class="bg-brand-50 p-10 rounded-3xl border border-brand-100/50 hover:shadow-xl transition-all duration-500">
            <div class="w-14 h-14 bg-brand-500 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-brand-500/20">
              <span class="i-mdi-whatsapp text-3xl"></span>
            </div>
            <h2 class="font-display text-2xl text-brand-700 mb-4">WhatsApp</h2>
            <p class="text-slate-600 mb-6 leading-relaxed text-lg">
              Agendamento rápido e direto para consultas presenciais ou teleterapia.
            </p>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="font-bold text-brand-600 text-lg hover:text-brand-700 flex items-center gap-2 group">
              (11) 99805-9125
              <span class="i-lucide-arrow-right group-hover:translate-x-1 transition-transform"></span>
            </a>
          </div>

          <div class="bg-white p-10 rounded-3xl border border-slate-100 hover:shadow-xl transition-all duration-500">
            <div class="w-14 h-14 bg-slate-100 text-brand-600 rounded-2xl flex items-center justify-center mb-6">
              <span class="i-lucide-map-pin text-3xl"></span>
            </div>
            <h2 class="font-display text-2xl text-brand-700 mb-4">Localização</h2>
            <p class="text-slate-600 mb-6 leading-relaxed text-lg">
              Av. Paulista, 509 - Conj. 1513<br />Bela Vista, São Paulo - SP
            </p>
            <a href="https://maps.app.goo.gl/3f8H2k2z1J3jL8z6A" target="_blank" rel="noopener noreferrer" class="font-bold text-brand-600 text-lg hover:text-brand-700 flex items-center gap-2 group">
              Ver no Google Maps
              <span class="i-lucide-arrow-right group-hover:translate-x-1 transition-transform"></span>
            </a>
          </div>

          <div class="bg-white p-10 rounded-3xl border border-slate-100 hover:shadow-xl transition-all duration-500">
            <div class="w-14 h-14 bg-slate-100 text-brand-600 rounded-2xl flex items-center justify-center mb-6">
              <span class="i-lucide-clock text-3xl"></span>
            </div>
            <h2 class="font-display text-2xl text-brand-700 mb-4">Horários</h2>
            <div class="space-y-3 text-slate-600">
              <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="font-bold">Seg - Sex</span>
                <span>08:00 às 20:00</span>
              </div>
              <div class="flex justify-between border-b border-slate-50 pb-2">
                <span class="font-bold">Sábado</span>
                <span>09:00 às 13:00</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white p-10 lg:p-14 rounded-[2.5rem] border border-slate-100 shadow-2xl relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-brand-50 rounded-bl-full opacity-50 transition-transform group-hover:scale-110"></div>
          
          <h2 class="font-display text-3xl text-brand-700 mb-8">Envie uma mensagem</h2>
          
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-widest">Nome Completo</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Ex: Maria Oliveira"
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-brand-500 focus:bg-white transition-all outline-none text-slate-700"
                required
              />
            </div>
            
            <div>
              <label for="email" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-widest">Seu melhor E-mail</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="seu@email.com"
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-brand-500 focus:bg-white transition-all outline-none text-slate-700"
                required
              />
            </div>

            <div>
              <label for="phone" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-widest">Telefone / WhatsApp</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                placeholder="(11) 99999-9999"
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-brand-500 focus:bg-white transition-all outline-none text-slate-700"
              />
            </div>

            <div>
              <label for="message" class="block text-xs font-bold text-slate-400 mb-2 uppercase tracking-widest">Como posso te ajudar?</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                placeholder="Conte-nos brevemente o que você busca..."
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-brand-500 focus:bg-white transition-all outline-none text-slate-700 resize-none"
                required
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full bg-brand-700 text-white py-5 rounded-full font-bold hover:bg-brand-800 transition-all uppercase tracking-widest text-sm shadow-xl shadow-brand-900/20 flex items-center justify-center gap-3 group"
            >
              Enviar Mensagem
              <span class="i-lucide-send text-lg transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"></span>
            </button>
          </form>
          
          <p class="mt-8 text-center text-sm text-slate-400">
            Prometo responder o mais breve possível.
          </p>
        </div>
      </div>
    </section>

    <!-- Map Section Placeholder - Premium look -->
    <section class="mt-32 container">
      <div class="w-full aspect-[21/9] rounded-[3rem] overflow-hidden grayscale contrast-125 border border-slate-100 shadow-xl opacity-90 hover:grayscale-0 transition-all duration-1000 cursor-pointer group relative">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.1973223062635!2d-46.65215752375837!3d-23.561352478800262!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce59c636f01479%3A0xc0c6448378891d46!2sAv.%20Paulista%2C%20509%20-%20Bela%20Vista%2C%20S%C3%A3o%20Paulo%20-%20SP%2C%2001311-000!5e0!3m2!1spt-BR!2sbr!4v1709400000000!5m2!1spt-BR!2sbr" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="absolute inset-0 grayscale transition-all duration-1000 hover:grayscale-0"
        ></iframe>
        <div class="absolute inset-0 pointer-events-none border-[12px] border-white/50 rounded-[3rem]"></div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>
