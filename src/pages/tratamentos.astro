---
import BaseLayout from '../layouts/BaseLayout.astro';
import Services from '../components/Services.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout 
  title="Tratamentos e Abordagens" 
  description="Conheça todos os tratamentos realizados pela Dra. Cleide Sarkis: Psicanálise, Regressão, Hipnose Clínica e Psicoterapia Transpessoal."
>
  
  <section class="pt-40 pb-20 bg-brand-50">
    <div class="container text-center">
      <h1 class="heading-1 mb-6">Nossos Tratamentos</h1>
      <p class="text-main text-slate-600 max-w-3xl mx-auto">Técnicas integradas para cuidar da sua saúde mental de forma profunda e personalizada.</p>
    </div>
  </section>

  <Services />

  <section class="section-padding container">
    <div class="max-w-4xl mx-auto">
      <h2 class="heading-2 mb-12 text-center text-brand-600">Qual abordagem é a ideal para você?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            title: 'Ansiedade & Estresse',
            text: 'Técnicas de hipnose e psicanálise para acalmar a mente e tratar a origem do nervosismo.',
            link: '/terapia-ansiedade/'
          },
          {
            title: 'Depressão & Desânimo',
            text: 'Resgate o sentido e a motivação através de um acompanhamento profundo e acolhedor.',
            link: '/terapia-depressao/'
          },
          {
            title: 'Traumas & Medos',
            text: 'A regressão e a terapia transpessoal auxiliam na ressignificação de eventos difíceis do passado.',
            link: '/terapia-traumas/'
          },
          {
            title: 'Relacionamentos',
            text: 'Entenda seus padrões de escolha e melhore sua forma de se conectar com os outros.',
            link: '/terapia-relacionamento/'
          }
        ].map(item => (
          <div class="p-8 border border-slate-100 rounded-3xl hover:bg-white hover:shadow-xl transition-all">
            <h3 class="heading-3 mb-4">{item.title}</h3>
            <p class="text-base-site text-slate-600 mb-6">{item.text}</p>
            <a href={item.link} class="text-brand-500 font-bold hover:gap-3 flex items-center gap-2 transition-all">
              Ver detalhes
              <span class="i-lucide-arrow-right"></span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding container reveal">
    <div class="max-w-4xl mx-auto bg-brand-600 rounded-[3rem] p-12 text-center text-white shadow-2xl">
      <h2 class="heading-2 text-white mb-6">Ficou com dúvidas sobre qual abordagem escolher?</h2>
      <p class="text-brand-100 mb-10 max-w-xl mx-auto">
        Não se preocupe em decidir sozinho. Na primeira sessão, conversaremos para entender qual caminho melhor se adapta ao seu momento.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="/primeira-sessao/" class="btn-ghost !border-white !text-white hover:!bg-white/10 no-underline">
          Como funciona a sessão?
        </a>
        <a href="/contato/" class="btn-primary !bg-white !text-brand-700 hover:!bg-brand-50 no-underline">
          Agendar primeiro contato
        </a>
      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>
